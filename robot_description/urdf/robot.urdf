<?xml version="1.0"?>
<robot name="myRobot">

	<material name="white">
		<color rgba="1 1 1 1"/>
	</material>
	<material name="yellow">
		<color rgba="1 1 0 1"/>
	</material>

	<link name="base_link">
		<visual>
			<geometry>
				<cylinder length="0.8" radius="0.2"/>
			</geometry>
			<material name="white"/>
			<origin xyz="0 0 0.4"/>
		</visual>

		<collision>
			<geometry>
				<cylinder length="0.8" radius="0.2"/>
			</geometry>
			<origin xyz="0 0 0.4"/>
		</collision>
	</link>

	<link name="second_segment">
		<visual>
				<geometry>
					<cylinder length="0.3" radius="0.25"/>
				</geometry>
				<origin xyz="0 0 0.15"/>
		</visual>

		<collision>
				<geometry>
					<cylinder length="0.3" radius="0.25"/>
				</geometry>
				<origin xyz="0 0 0.15"/>
		</collision>
	</link>
	<joint name="second_segment_joint" type="revolute">
		<axis xyz="0 0 1"/>
		<limit effort="1000.0" lower="-0.4" upper="2" velocity="0.5"/>
		<parent link="base_link"/>
		<child link="second_segment"/>	
		<origin xyz="0 0 0.8" />
	</joint>

	<link name="third_segment">
		<visual>
				<geometry>
					<cylinder length="0.9" radius="0.15"/>
				</geometry>
				<origin xyz="0 0 0.45"/>
				<material name="white"/>
		</visual>
		<collision>
				<geometry>
					<cylinder length="0.9" radius="0.15"/>
				</geometry>
				<origin xyz="0 0 0.45"/>
		</collision>
	</link>
	<joint name="third_segment_joint" type="revolute">
		<axis xyz="0 1 0"/>
		<limit effort="1000.0" lower="-0.4" upper="1.2" velocity="0.5"/>
		<parent link="second_segment"/>
		<child link="third_segment"/>	
		<origin xyz="0 0 0.3" />
	</joint>

	<link name="forth_segment">
		<visual>
			<geometry>
					<cylinder length="0.9" radius="0.12"/>
			</geometry>
			<origin xyz="0 0 0.45"/>
		</visual>
		<collision>
			<geometry>
					<cylinder length="0.9" radius="0.12"/>
			</geometry>
			<origin xyz="0 0 0.45"/>
		</collision>
	</link>
	<joint name="forth_segment_joint" type="revolute">
		<axis xyz="0 1 0"/>
		<limit effort="1000.0" lower="-0.4" upper="1.2" velocity="0.5"/>
		<parent link="third_segment"/>
		<child link="forth_segment"/>	
		<origin xyz="0 0 0.9" />
	</joint>

	<link name="gripper_base">
		<visual>
			<geometry>
				<box size="0.3 0.4 0.03"/>
			</geometry>
			<origin xyz="0 0 0.015"/>
			<material name="yellow"/>
		</visual>
		<collision>
			<geometry>
				<box size="0.3 0.4 0.03"/>
			</geometry>
			<origin xyz="0 0 0.015"/>
		</collision>
	</link>
	<joint name="gripper_joint" type="fixed">
		<parent link="forth_segment"/>
		<child link="gripper_base"/>
		<origin xyz="0 0 0.9"/>
	</joint>

	<link name="right_gripper">
		<visual>
			<geometry>
				<box size="0.3 0.03 0.2"/>
			</geometry>
			<origin xyz="0 0.1 0.075"/>
			<material name="yellow"/>
		</visual>

		<collision>
			<geometry>
				<box size="0.3 0.03 0.2"/>
			</geometry>
			<origin xyz="0 0.1 0.075"/>
			<material name="yellow"/>
		</collision>
	</link>
	<joint name="right_gripper_joint" type="prismatic">
		<axis xyz="0 1 0"/>
		<limit velocity="0.5" effort="1000" upper="0.06" lower="-0.06"/>
		<parent link="gripper_base"/>
		<child link="right_gripper"/>
		<origin xyz="0 0 0.015"/>
	</joint>

	<link name="left_gripper">
		<visual>
			<geometry>
				<box size="0.3 0.03 0.2"/>
			</geometry>
			<origin xyz="0 -0.1 0.075"/>
			<material name="yellow"/>
		</visual>
		<collision>
			<geometry>
				<box size="0.3 0.03 0.2"/>
			</geometry>
			<origin xyz="0 -0.1 0.075"/>
		</collision>
	</link>
	<joint name="left_gripper_joint" type="prismatic">
		<axis xyz="0 1 0"/>
		<limit velocity="0.5" effort="1000" upper="0.06" lower="-0.06"/>
		<parent link="gripper_base"/>
		<child link="left_gripper"/>
		<origin xyz="0 0 0.015"/>
	</joint>

</robot>
